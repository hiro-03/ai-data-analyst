{
  "Comment": "Weather Observation Pipeline (Local)",
  "StartAt": "ObserveWeather",
  "States": {
    "ObserveWeather": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:ap-northeast-1:123456789012:function:weather-observation-api",
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "Fallback"
        }
      ],
      "End": true
    },
    "Fallback": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:ap-northeast-1:123456789012:function:weather-fallback-api",
      "End": true
    }
  }
}