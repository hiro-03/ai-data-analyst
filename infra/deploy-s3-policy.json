{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3ForDeployment",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:ListBucket",
        "s3:DeleteObject",
        "s3:AbortMultipartUpload",
        "s3:PutObjectAcl",
        "s3:PutObjectTagging"
      ],
      "Resource": [
        "arn:aws:s3:::aws-sam-cli-managed-default-samclisourcebucket-u5eqh8km81jw",
        "arn:aws:s3:::aws-sam-cli-managed-default-samclisourcebucket-u5eqh8km81jw/*"
      ]
    }
  ]
}